{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "services": [
      {
        "name": "backend",
        "build": {
          "builder": "DOCKERFILE",
          "dockerfilePath": "backend/Dockerfile"
        },
        "deploy": {
          "restartPolicyType": "ON_FAILURE"
        }
      },
      {
        "name": "frontend",
        "build": {
          "builder": "DOCKERFILE",
          "dockerfilePath": "frontend/Dockerfile"
        },
        "deploy": {
          "restartPolicyType": "ON_FAILURE"
        }
      }
    ]
  }
}